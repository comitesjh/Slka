const MINHA_CHAVE = "AIzaSyAuUEYw2caUrDuoNejx7kqzpSoSzbl3jA8";

async function enviarMensagem() {
    const prompt = "Oi Flayky, tudo bem?"; // Aqui vai o que o usuário digitar

    const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${MINHA_CHAVE}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
            contents: [{
                parts: [{ text: prompt }]
            }]
        })
    });

    const data = await response.json();
    const respostaDaIA = data.candidates[0].content.parts[0].text;
    
    console.log("A Flayky disse:", respostaDaIA);
    
    // Lembrar da conversa (LocalStorage)
    localStorage.setItem("ultima_resposta", respostaDaIA);
}
