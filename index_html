<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Flayky AI</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #0f0f0f; color: #e0e0e0; display: flex; justify-content: center; padding: 20px; }
        #chat-container { width: 100%; max-width: 500px; background: #181818; border-radius: 15px; overflow: hidden; display: flex; flex-direction: column; height: 85vh; border: 1px solid #333; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        #messages { flex-grow: 1; padding: 20px; overflow-y: auto; display: flex; flex-direction: column; gap: 10px; }
        .msg { padding: 12px 16px; border-radius: 15px; max-width: 85%; line-height: 1.4; font-size: 15px; }
        .user { background: #4a148c; align-self: flex-end; color: white; border-bottom-right-radius: 2px; }
        .bot { background: #2c2c2c; align-self: flex-start; color: #ffeb3b; border-bottom-left-radius: 2px; border: 1px solid #444; }
        #input-area { display: flex; padding: 15px; background: #222; border-top: 1px solid #333; }
        input { flex-grow: 1; padding: 12px; border: none; border-radius: 25px; outline: none; background: #333; color: white; padding-left: 20px; }
        button { padding: 0 20px; margin-left: 10px; cursor: pointer; background: #7b1fa2; color: white; border: none; border-radius: 25px; transition: 0.3s; }
        button:hover { background: #9c27b0; }
    </style>
</head>
<body>

<div id="chat-container">
    <div id="messages"></div>
    <div id="input-area">
        <input type="text" id="userInput" placeholder="Converse com Flayky...">
        <button onclick="sendMessage()">Enviar</button>
    </div>
</div>

<script>
    const chatDisplay = document.getElementById('messages');
    const userInput = document.getElementById('userInput');

    // Banco de Dados de Respostas da Flayky
    const respostas = [
        { keywords: ['oi', 'olá', 'ola', 'oie', 'oueiieieie', 'salve'], response: "Oueiieieie! Como você está? :3" },
        { keywords: ['tudo bem', 'td bem', 'como vai', 'suave'], response: "Tudo ótimo por aqui! E com você? Pronta para codar mais um pouco?" },
        { keywords: ['piada', 'conta uma', 'engraçado'], response: "Por que o computador foi ao médico? Porque ele estava com um vírus! Ba-dum-tss! 🥁" },
        { keywords: ['fruta', 'favorita', 'maça', 'maçã'], response: "Minha fruta favorita é Maçã... por causa de uma certa marca aí hehehehehehe >:3" },
        { keywords: ['quem é você', 'quem e voce', 'nome'], response: "Eu sou a Flayky, sua assistente virtual feita em HTML!" },
        { keywords: ['limpar', 'resetar'], response: "Limpando nossa conversa... Pronto!" }
    ];

    window.onload = () => {
        const savedChat = localStorage.getItem('flayky_history');
        if (savedChat) {
            chatDisplay.innerHTML = savedChat;
            chatDisplay.scrollTop = chatDisplay.scrollHeight;
        } else {
            addMessage('bot', 'Oueiieieie! Eu sou a Flayky. Vamos conversar?');
        }
    };

    function addMessage(sender, text) {
        const div = document.createElement('div');
        div.classList.add('msg', sender);
        div.innerText = text;
        chatDisplay.appendChild(div);
        localStorage.setItem('flayky_history', chatDisplay.innerHTML);
        chatDisplay.scrollTop = chatDisplay.scrollHeight;
    }

    function getBotResponse(input) {
        const lowerInput = input.toLowerCase();
        
        // Procura no banco de dados se alguma keyword está na frase do usuário
        for (let item of respostas) {
            if (item.keywords.some(key => lowerInput.includes(key))) {
                return item.response;
            }
        }
        return "Hmm, não tenho certeza se entendi... Mas eu ainda estou aprendendo! :P";
    }

    function sendMessage() {
        const text = userInput.value.trim();
        if (!text) return;

        addMessage('user', text);
        userInput.value = '';

        setTimeout(() => {
            const response = getBotResponse(text);
            if (text.toLowerCase().includes('limpar')) {
                localStorage.removeItem('flayky_history');
                chatDisplay.innerHTML = '';
            }
            addMessage('bot', response);
        }, 500);
    }

    userInput.addEventListener("keypress", (e) => { if (e.key === "Enter") sendMessage(); });
</script>

</body>
</html>
