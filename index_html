<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Editor de Vídeo Simples</title>
  <style>
    body {
      font-family: Arial;
      text-align: center;
      background: #111;
      color: white;
    }

    button {
      padding: 10px 20px;
      margin: 10px;
      border: none;
      background: #ff0055;
      color: white;
      cursor: pointer;
      border-radius: 8px;
    }

    video {
      margin-top: 20px;
      max-width: 90%;
      border-radius: 10px;
    }

    .controls {
      margin-top: 15px;
    }

    input {
      width: 200px;
    }

    #downloadBtn {
      position: fixed;
      top: 10px;
      right: 10px;
      background: green;
    }
  </style>
</head>
<body>

<h1>Editor de Vídeo</h1>

<button onclick="abrirGaleria()">Escolher Vídeo</button>

<input type="file" id="fileInput" accept="video/*" style="display:none">

<br>

<video id="video" controls></video>

<div class="controls">
  <p>Volume</p>
  <input type="range" min="0" max="1" step="0.1" onchange="mudarVolume(this.value)">

  <p>Velocidade</p>
  <input type="range" min="0.5" max="2" step="0.1" onchange="mudarVelocidade(this.value)">

  <p>Brilho</p>
  <input type="range" min="50" max="150" step="10" onchange="mudarBrilho(this.value)">
</div>

<button id="downloadBtn" onclick="baixarVideo()">Baixar Vídeo</button>

<script>
  let video = document.getElementById("video");
  let fileInput = document.getElementById("fileInput");

  function abrirGaleria() {
    fileInput.click();
  }

  fileInput.onchange = function(event) {
    let file = event.target.files[0];
    let url = URL.createObjectURL(file);
    video.src = url;
  }

  function mudarVolume(valor) {
    video.volume = valor;
  }

  function mudarVelocidade(valor) {
    video.playbackRate = valor;
  }

  function mudarBrilho(valor) {
    video.style.filter = `brightness(${valor}%)`;
  }

  function baixarVideo() {
    alert("⚠️ Download real com edição completa precisa de backend ou biblioteca pesada (ex: FFmpeg). Esse botão é só demonstração.");
    
    let link = document.createElement("a");
    link.href = video.src;
    link.download = "video_editado.mp4";
    link.click();
  }
</script>

</body>
</html>
